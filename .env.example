# Connectivity
AMS_POLICY_HOST=https://host/base/path
AMS_RULE_HOST=https://host/base/path
HEALTH_PATH=/actuator/health
DB_DSN=jdbc:oracle:thin:@host:1521:sid
N8N_CALLBACK_URL=https://n8n.host/webhook/qa-result
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.2
QA_ENVIRONMENT=UAT
AI_SUMMARY_TIMEOUT=20

# Auth (JWT login before health check)
AUTH_LOGIN_URL=https://host/user/api/v1/arizona/auth/ec/login
AUTH_USERNAME=batch_user
AUTH_PASSWORD=changeme
AUTH_TENANT=ec

# DB schema — ren-data
FLYWAY_HISTORY_TABLE=flyway_schema_history
RENEWAL_TABLE=frd_fixed_renewal_data
RENEWAL_MIGRATION_ID_FIELD=migration_id
RENEWAL_BLOCKED_FIELD=BLOCKED_RENEWAL
RENEWAL_PLATE_FIELD=PLACAS
QA_SAMPLE_SIZE=10
QA_PLATE_DELAY=0
QA_QUOTE_MIN_OK_COUNT=1
QA_QUOTE_TOLERANCE=20.00

# DB schema — rules
RULES_TABLE=ams_rule_entry
RULES_ENTITY_FIELD=entity
RULES_MIGRATION_ID_FIELD=migration_id

# Operation
QA_TASKS_DB=/data/qa_tasks.db
RETENTION_DAYS=90
PORT=5000
