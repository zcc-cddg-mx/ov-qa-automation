# Connectivity
AMS_POLICY_HOST=ams-policy-dev:8080
AMS_RULE_HOST=ams-rule-dev:8080
HEALTH_PATH=/actuator/health
DB_DSN=postgresql://user:pass@db-dev:5432/amsdb
N8N_CALLBACK_URL=https://n8n.host/webhook/qa-result

# DB schema — ren-data
FLYWAY_HISTORY_TABLE=flyway_schema_history
RENEWAL_TABLE=frd_fixed_renewal_data
RENEWAL_MIGRATION_ID_FIELD=migration_id
RENEWAL_BLOCKED_FIELD=renewal_blocked

# DB schema — rules
RULES_TABLE=ams_rule_entry
RULES_ENTITY_FIELD=entity
RULES_MIGRATION_ID_FIELD=migration_id

# Operation
QA_TASKS_DB=/data/qa_tasks.db
RETENTION_DAYS=90
PORT=5000
